# Copy to .env.local and fill in.
# Without this key, the chat panel falls back to a scripted canned reply.
DEEPSEEK_API_KEY=
# Optional — defaults shown:
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Shared secret for /admin (the soul-editor page).
# Use any long random string; the admin page will ask you to enter it.
ADMIN_SECRET_KEY=
